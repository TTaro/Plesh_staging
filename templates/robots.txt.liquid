# Robots & Agent policy
# Checkouts are for humans.
# * Automated scraping, "buy-for-me" agents, or any end-to-end flow that
#   completes payment without a final human review step is not permitted.
# * Legitimate integrators must use the official Checkout Kit:
#   https://www.shopify.com/checkout-kit
#
# Terms of Service: https://www.shopify.com/legal/terms
# Contact: bots@shopify.com

{% for group in robots.default_groups -%}
User-agent: {{ group.user_agent.value }}
{%- for rule in group.rules -%}
{%- unless rule.value contains '/policies/' -%}
{{ rule }}
{%- endunless -%}
{%- endfor -%}
{% if group.sitemap != blank %}
{{ group.sitemap }}
{% endif %}

{%- endfor -%}