          "settings": {
            "text": "<p>+ de 500 puntos de venta activos <\/p>",
            "size": 100,
            "margin_bottom": 16
          }
        },
        "heading_PfqkdX": {
          "type": "heading",
          "settings": {
            "text": "<p>Plesh B2B (Business to business)<\/p>",
            "size": 100,
            "heading_highlight_type": "underline-hand-drawn",
            "highlight_color": "#000000",
            "highlight_text_color": ""
          }
        },
        "text_wR7ip7": {
          "type": "text",
          "settings": {
            "text": "<p>¿Te interesa vender Plesh en tu cafetería o comercio? <br\/>¡Es muy fácil! <br\/><br\/>1. Rellena el siguiente formulario <br\/>2. Recibe la información y condiciones <br\/>3. Haz tu pedido<br\/><br\/>Welcome to the PLESH COMMUNITY<\/p>",
            "size": 100
          }
        }
      },
      "block_order": [
